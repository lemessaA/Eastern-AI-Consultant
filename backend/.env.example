# Eastern AI Consultant API — environment variables
ENVIRONMENT=development
DEBUG=true

# Database (async URL for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://eastern_ai:eastern_ai@localhost:5432/eastern_ai
SYNC_DATABASE_URL=postgresql+psycopg2://eastern_ai:eastern_ai@localhost:5432/eastern_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=replace_with_64_char_random_string
JWT_SECRET=replace_with_64_char_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI providers
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDINARY_URL=

# Vector store
VECTOR_STORE_PATH=/app/chroma_db

# Rate limit
RATE_LIMIT_PER_MINUTE=60
