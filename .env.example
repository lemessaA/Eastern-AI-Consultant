# =============================================================================
# Eastern AI Consultant — Root environment variables
# Copy to .env and fill in real values. Do NOT commit .env.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=eastern_ai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=eastern_ai
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- API (FastAPI) ---
API_PORT=8000
API_SECRET_KEY=replace_with_64_char_random_string
API_JWT_SECRET=replace_with_64_char_random_string
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI providers ---
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Storage ---
STORAGE_BACKEND=local   # local | s3 | cloudinary
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDINARY_URL=

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@easternaiconsultant.com

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
