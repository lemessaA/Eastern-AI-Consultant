# Eastern AI Consultant — frontend (Next.js public env)
#
# Production (API URL): Render — https://<service>.onrender.com · Vercel API — https://<project>.vercel.app
# See docs/vercel.md for a two-project Vercel setup (frontend + backend).

# Production (Vercel): full API origin only, https, no trailing slash (e.g. https://your-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Eastern AI Consultant
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
